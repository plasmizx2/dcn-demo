# Copy to backend/.env for local dev, or set these in your host (Render/Fly/etc.).
# Never commit real secrets.

# Required — PostgreSQL (Render Postgres provides this; use Internal URL from the same region)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Public URL of this API (OAuth redirects and links). No trailing slash.
# Example: https://dcn-demo.onrender.com
BASE_URL=http://localhost:8000

# OAuth (set the callback URLs in Google Cloud / GitHub to ${BASE_URL}/auth/google/callback etc.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional — this email gets the ceo role on login
CEO_EMAIL=
